<mujoco model="quadruped">

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.5"/>
    <geom condim="3" friction="0.8 0.02 0.01"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="20 20 0.1" rgba="0.75 0.75 0.75 1"
          condim="3" friction="0.8 0.02 0.01"/>

    <body name="torso" pos="0 0 0.5">
      <freejoint name="root"/>
      <geom name="torso_geom" type="box" size="0.3 0.15 0.08"
            rgba="0.3 0.6 0.9 1" mass="5"/>

      <body name="fl_thigh" pos="0.25 0.15 0">
        <joint name="fl_hip" type="hinge" axis="0 1 0" range="-60 60" damping="0.5"/>
        <geom name="fl_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
              size="0.04" rgba="0.9 0.4 0.2 1" mass="0.5"/>
        <body name="fl_shin" pos="0 0 -0.2">
          <joint name="fl_knee" type="hinge" axis="0 1 0" range="-120 0" damping="0.5"/>
          <geom name="fl_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
                size="0.03" rgba="0.9 0.6 0.2 1" mass="0.3"/>
          <site name="fl_foot" pos="0 0 -0.21" size="0.04" rgba="1 0 0 1"/>
        </body>
      </body>

      <body name="fr_thigh" pos="0.25 -0.15 0">
        <joint name="fr_hip" type="hinge" axis="0 1 0" range="-60 60" damping="0.5"/>
        <geom name="fr_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
              size="0.04" rgba="0.9 0.4 0.2 1" mass="0.5"/>
        <body name="fr_shin" pos="0 0 -0.2">
          <joint name="fr_knee" type="hinge" axis="0 1 0" range="-120 0" damping="0.5"/>
          <geom name="fr_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
                size="0.03" rgba="0.9 0.6 0.2 1" mass="0.3"/>
          <site name="fr_foot" pos="0 0 -0.21" size="0.04" rgba="1 0 0 1"/>
        </body>
      </body>

      <body name="bl_thigh" pos="-0.25 0.15 0">
        <joint name="bl_hip" type="hinge" axis="0 1 0" range="-60 60" damping="0.5"/>
        <geom name="bl_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
              size="0.04" rgba="0.9 0.4 0.2 1" mass="0.5"/>
        <body name="bl_shin" pos="0 0 -0.2">
          <joint name="bl_knee" type="hinge" axis="0 1 0" range="-120 0" damping="0.5"/>
          <geom name="bl_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
                size="0.03" rgba="0.9 0.6 0.2 1" mass="0.3"/>
          <site name="bl_foot" pos="0 0 -0.21" size="0.04" rgba="1 0 0 1"/>
        </body>
      </body>

      <body name="br_thigh" pos="-0.25 -0.15 0">
        <joint name="br_hip" type="hinge" axis="0 1 0" range="-60 60" damping="0.5"/>
        <geom name="br_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
              size="0.04" rgba="0.9 0.4 0.2 1" mass="0.5"/>
        <body name="br_shin" pos="0 0 -0.2">
          <joint name="br_knee" type="hinge" axis="0 1 0" range="-120 0" damping="0.5"/>
          <geom name="br_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.2"
                size="0.03" rgba="0.9 0.6 0.2 1" mass="0.3"/>
          <site name="br_foot" pos="0 0 -0.21" size="0.04" rgba="1 0 0 1"/>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <position name="fl_hip_act"  joint="fl_hip"  kp="50" ctrlrange="-1.05 1.05"/>
    <position name="fl_knee_act" joint="fl_knee" kp="50" ctrlrange="-2.09 0"/>
    <position name="fr_hip_act"  joint="fr_hip"  kp="50" ctrlrange="-1.05 1.05"/>
    <position name="fr_knee_act" joint="fr_knee" kp="50" ctrlrange="-2.09 0"/>
    <position name="bl_hip_act"  joint="bl_hip"  kp="50" ctrlrange="-1.05 1.05"/>
    <position name="bl_knee_act" joint="bl_knee" kp="50" ctrlrange="-2.09 0"/>
    <position name="br_hip_act"  joint="br_hip"  kp="50" ctrlrange="-1.05 1.05"/>
    <position name="br_knee_act" joint="br_knee" kp="50" ctrlrange="-2.09 0"/>
  </actuator>

  <sensor>
    <touch name="fl_touch" site="fl_foot"/>
    <touch name="fr_touch" site="fr_foot"/>
    <touch name="bl_touch" site="bl_foot"/>
    <touch name="br_touch" site="br_foot"/>
  </sensor>

</mujoco>
